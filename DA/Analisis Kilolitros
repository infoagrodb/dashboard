/* ── Mapas de calor Finca x Ciclo, uno por Grupo ── */
function heatColor(v, min, max) {
  if (max<=min) return 'rgba(82,183,136,.3)';
  const t = Math.max(0, Math.min(1, (v-min)/(max-min)));
  const r = Math.round(82 + (231-82)*t);
  const g = Math.round(183 + (111-183)*t);
  const b = Math.round(136 + (81-136)*t);
  return `rgba(${r},${g},${b},.4)`;
}

function renderHeatmaps(ciclos, fincas, treeFGC, mznByCF) {
  const key = currentMetric;
  const grupos = [...GRUPO_ORDEN.filter(g=>treeFGC[g]), ...Object.keys(treeFGC).filter(g=>!GRUPO_ORDEN.includes(g))];
  const fincasOrd = [...fincas].sort();

  let html = '';
  grupos.forEach(grupo => {
    const vals = [];
    fincasOrd.forEach(f => ciclos.forEach(c => {
      const cell = treeFGC[grupo]?.[f]?.[c];
      const mzn = mznByCF[`${c}|${f}`]||0;
      if (cell && mzn>0) vals.push(cell[key]/mzn);
    }));
    const min = vals.length ? Math.min(...vals) : 0;
    const max = vals.length ? Math.max(...vals) : 0;

    let t = `<div class="heat-card"><div class="heat-title">${grupo}</div><table class="heat-table"><thead><tr><th></th>`;
    ciclos.forEach(c => t += `<th>${c.replace('Mani ','')}</th>`);
    t += `</tr></thead><tbody>`;
    fincasOrd.forEach(f => {
      t += `<tr><td class="heat-finca">${f}</td>`;
      ciclos.forEach(c => {
        const cell = treeFGC[grupo]?.[f]?.[c];
        const mzn = mznByCF[`${c}|${f}`]||0;
        const val = (cell && mzn>0) ? cell[key]/mzn : null;
        if (val!=null) {
          t += `<td style="background:${heatColor(val,min,max)}" onclick="openHeatCell('${grupo.replace(/'/g,"\\'")}','${f.replace(/'/g,"\\'")}','${c}')">${N(val,1)}</td>`;
        } else {
          t += `<td class="heat-empty">—</td>`;
        }
      });
      t += `</tr>`;
    });
    t += `</tbody></table></div>`;
    html += t;
  });

  document.getElementById('heat-container').innerHTML = html || '<p style="font-size:11px;color:var(--ink3)">Sin datos suficientes.</p>';
}

function openHeatCell(grupo, finca, ciclo) {
  if (!CTX) return;
  const rows = CTX.rows.filter(r => r.Finca===finca && r.Ciclo===ciclo &&
    classifyGrupo(r.Clasificacion, r.CuentaContableDescripcion || r.CUENTA_CONTABLE).grupo===grupo);
  let kl=0, usd=0;
  const porFamilia = {};
  rows.forEach(r => {
    const { familia } = classifyGrupo(r.Clasificacion, r.CuentaContableDescripcion || r.CUENTA_CONTABLE);
    const k = (parseFloat(r.Cantidad_Consumo)||0)*KL_FACTOR(r.um);
    const u = parseFloat(r.Monto_Consumo)||0;
    kl += k; usd += u;
    if (!porFamilia[familia]) porFamilia[familia] = {kl:0,usd:0};
    porFamilia[familia].kl += k; porFamilia[familia].usd += u;
  });
  const mzn = CTX.mznByCicloFinca[`${ciclo}|${finca}`]||0;

  document.getElementById('modal-title').textContent = `${grupo} · ${finca}`;
  document.getElementById('modal-sub').textContent = `Ciclo ${ciclo}`;
  let b = `<div class="modal-sum">
    <div class="it"><b>${N(kl,0)}</b><span>KL total</span></div>
    <div class="it"><b>${U(usd,0)}</b><span>U$ total</span></div>
    <div class="it"><b>${mzn>0?N(kl/mzn,2):'—'}</b><span>KL/Mzn</span></div>
    <div class="it"><b>${mzn>0?U(usd/mzn,3):'—'}</b><span>U$/Mzn</span></div>
  </div>`;
  b += `<table><thead><tr><th class="left">Familia</th><th>KL</th><th>U$</th></tr></thead><tbody>`;
  Object.keys(porFamilia).sort((a,b2)=>porFamilia[b2][currentMetric]-porFamilia[a][currentMetric]).forEach(f => {
    b += `<tr><td class="left">${f}</td><td>${N(porFamilia[f].kl,0)}</td><td>${U(porFamilia[f].usd,0)}</td></tr>`;
  });
  b += `</tbody></table>`;
  document.getElementById('modal-body').innerHTML = b;
  document.getElementById('modal-bg').classList.add('show');
}

function renderChartFinca(ciclos, fincas, totFC, mznByCF) {
  if (charts['ch-finca']) charts['ch-finca'].destroy();
  const key = currentMetric;
  const datasets = ciclos.map(c => ({
    label: c,
    data: fincas.map(f => {
      const t = totFC[`${f}|${c}`];
      const mzn = mznByCF[`${c}|${f}`]||0;
      return t && mzn>0 ? +(t[key]/mzn).toFixed(2) : 0;
    }),
    backgroundColor: colorOf(c), borderRadius:4, maxBarThickness:22
  }));
  charts['ch-finca'] = new Chart(document.getElementById('ch-finca'), {
    type:'bar',
    data:{ labels: fincas, datasets },
    options:{
      responsive:true, maintainAspectRatio:false,
      plugins:{ legend:{position:'bottom', labels:{font:{size:10},boxWidth:10}} },
      scales:{
        x:{ ticks:{font:{size:10}}, grid:{display:false} },
        y:{ ticks:{font:{size:10}}, grid:{color:'#eef3f0'}, title:{display:true,text:unitLbl()+'/Mzn',font:{size:9}} }
      }
    }
  });
}

/* ── Tabla Grupo/Familia (agregada) con clic -> detalle por finca ── */
function renderGrupoFamilia(treeGF, ciclos) {
  const key = currentMetric;
  let h = `<thead><tr><th class="left">Grupo / Familia</th>`;
  ciclos.forEach(c => h += `<th class="ciclo">${c}</th>`);
  h += `</tr></thead><tbody>`;

  const grupos = [...GRUPO_ORDEN.filter(g=>treeGF[g]), ...Object.keys(treeGF).filter(g=>!GRUPO_ORDEN.includes(g))];
  const grandTot = ciclos.map(()=>0);

  grupos.forEach(grupo => {
    const familias = Object.keys(treeGF[grupo]).sort();
    const gTot = ciclos.map(c => familias.reduce((s,f)=>s+(treeGF[grupo][f][c]?.[key]||0),0));
    gTot.forEach((v,i)=>grandTot[i]+=v);

    h += `<tr class="rf"><td class="dim">${grupo}</td>`;
    gTot.forEach((v,ci) => h += `<td onclick="openGrupoDetail('${grupo.replace(/'/g,"\\'")}',null,'${ciclos[ci]}')">${v>0?(key==='kl'?N(v,0):U(v,0)):'—'}</td>`);
    h += `</tr>`;

    if (familias.length>1 || (familias[0] && familias[0]!==grupo)) {
      familias.forEach(fam => {
        h += `<tr class="rc"><td class="dim">${fam}</td>`;
        ciclos.forEach(c => {
          const v = treeGF[grupo][fam][c]?.[key] || 0;
          h += `<td onclick="openGrupoDetail('${grupo.replace(/'/g,"\\'")}','${fam.replace(/'/g,"\\'")}','${c}')">${v>0?(key==='kl'?N(v,0):U(v,0)):'—'}</td>`;
        });
        h += `</tr>`;
      });
    }
  });

  h += `<tr class="rt"><td class="dim">Total general</td>`;
  grandTot.forEach(v => h += `<td><strong>${key==='kl'?N(v,0):U(v,0)}</strong></td>`);
  h += `</tr></tbody>`;
  document.getElementById('t-grupo').innerHTML = h;
}

/* ── Tabla Grupo/Familia dividida entre Mzn Sembrada del ciclo ── */
function renderGrupoFamiliaMzn(treeGF, ciclos, mznByCiclo) {
  const key = currentMetric;
  let h = `<thead><tr><th class="left">Grupo / Familia</th>`;
  ciclos.forEach(c => h += `<th class="ciclo">${c}</th>`);
  h += `</tr></thead><tbody>`;

  const grupos = [...GRUPO_ORDEN.filter(g=>treeGF[g]), ...Object.keys(treeGF).filter(g=>!GRUPO_ORDEN.includes(g))];
  const grandTot = ciclos.map(()=>0);

  grupos.forEach(grupo => {
    const familias = Object.keys(treeGF[grupo]).sort();
    const gTot = ciclos.map(c => familias.reduce((s,f)=>s+(treeGF[grupo][f][c]?.[key]||0),0));
    gTot.forEach((v,i)=>grandTot[i]+=v);

    h += `<tr class="rf"><td class="dim">${grupo}</td>`;
    gTot.forEach((v,ci) => {
      const mzn = mznByCiclo[ciclos[ci]]||0;
      const val = mzn>0 ? v/mzn : 0;
      h += `<td onclick="openGrupoDetail('${grupo.replace(/'/g,"\\'")}',null,'${ciclos[ci]}')">${val>0?N(val,1):'—'}</td>`;
    });
    h += `</tr>`;

    if (familias.length>1 || (familias[0] && familias[0]!==grupo)) {
      familias.forEach(fam => {
        h += `<tr class="rc"><td class="dim">${fam}</td>`;
        ciclos.forEach(c => {
          const v = treeGF[grupo][fam][c]?.[key] || 0;
          const mzn = mznByCiclo[c]||0;
          const val = mzn>0 ? v/mzn : 0;
          h += `<td onclick="openGrupoDetail('${grupo.replace(/'/g,"\\'")}','${fam.replace(/'/g,"\\'")}','${c}')">${val>0?N(val,1):'—'}</td>`;
        });
        h += `</tr>`;
      });
    }
  });

  h += `<tr class="rt"><td class="dim">Total general</td>`;
  grandTot.forEach((v,ci) => {
    const mzn = mznByCiclo[ciclos[ci]]||0;
    h += `<td><strong>${mzn>0?N(v/mzn,1):'—'}</strong></td>`;
  });
  h += `</tr></tbody>`;
  document.getElementById('t-grupo-mzn').innerHTML = h;
}

function openGrupoDetail(grupo, familia, ciclo) {
  if (!CTX) return;
  const rows = CTX.rows.filter(r => {
    if (r.Ciclo !== ciclo) return false;
    const cl = classifyGrupo(r.Clasificacion, r.CuentaContableDescripcion || r.CUENTA_CONTABLE);
    return cl.grupo===grupo && (familia==null || cl.familia===familia);
  });
  const byFinca = {};
  rows.forEach(r => {
    const kl = (parseFloat(r.Cantidad_Consumo)||0)*KL_FACTOR(r.um);
    const usd = parseFloat(r.Monto_Consumo)||0;
    if (!byFinca[r.Finca]) byFinca[r.Finca] = {kl:0,usd:0};
    byFinca[r.Finca].kl += kl; byFinca[r.Finca].usd += usd;
  });

  document.getElementById('modal-title').textContent = familia ? `${grupo} · ${familia}` : grupo;
  document.getElementById('modal-sub').textContent = `Ciclo ${ciclo} · desglose por finca`;
  let b = `<table><thead><tr><th class="left">Finca</th><th>KL</th><th>U$</th><th>KL/Mzn</th><th>U$/Mzn</th></tr></thead><tbody>`;
  Object.keys(byFinca).sort((a,b)=> (currentMetric==='kl'?byFinca[b].kl-byFinca[a].kl:byFinca[b].usd-byFinca[a].usd)).forEach(f => {
    const v = byFinca[f];
    const mzn = CTX.mznByCicloFinca[`${ciclo}|${f}`]||0;
    b += `<tr><td class="left">${f}</td><td>${N(v.kl,0)}</td><td>${U(v.usd,0)}</td><td>${mzn>0?N(v.kl/mzn,1):'—'}</td><td>${mzn>0?U(v.usd/mzn,2):'—'}</td></tr>`;
  });
  b += `</tbody></table>`;
  document.getElementById('modal-body').innerHTML = b;
  document.getElementById('modal-bg').classList.add('show');
}

function renderChartSector(ciclos, fincas, totFC, mznByCF) {
  if (charts['ch-sector']) charts['ch-sector'].destroy();
  const key = currentMetric;
  const sectores = [...new Set(fincas.map(f=>sectorOf(f)))].sort();
  const datasets = ciclos.map(c => ({
    label: c,
    data: sectores.map(sec => {
      let val=0, mzn=0;
      fincas.filter(f=>sectorOf(f)===sec).forEach(f => {
        const t = totFC[`${f}|${c}`];
        if (t) val += t[key];
        mzn += mznByCF[`${c}|${f}`]||0;
      });
      return mzn>0 ? +(val/mzn).toFixed(2) : 0;
    }),
    backgroundColor: colorOf(c), borderRadius:4, maxBarThickness:40
  }));
  charts['ch-sector'] = new Chart(document.getElementById('ch-sector'), {
    type:'bar',
    data:{ labels: sectores, datasets },
    options:{
      responsive:true, maintainAspectRatio:false,
      plugins:{ legend:{position:'bottom', labels:{font:{size:10},boxWidth:10}} },
      scales:{
        x:{ ticks:{font:{size:10}}, grid:{display:false} },
        y:{ ticks:{font:{size:10}}, grid:{color:'#eef3f0'}, title:{display:true,text:unitLbl()+'/Mzn',font:{size:9}} }
      }
    }
  });
}

function renderMatrix(tree, ciclos) {
  const key = currentMetric;
  _detailStore = {};
  let h = `<thead><tr><th class="left">Finca / Categoría / Cuenta</th>`;
  ciclos.forEach(c => h += `<th class="ciclo">${c}</th>`);
  h += `</tr></thead><tbody>`;

  const grandTot = ciclos.map(()=>0);

  Object.keys(tree).sort().forEach(finca => {
    const fTot = ciclos.map(c => { let v=0; Object.values(tree[finca]).forEach(cts=>Object.values(cts).forEach(cy=>{v+=cy[c]?.[key]||0;})); return v; });
    fTot.forEach((v,i)=>grandTot[i]+=v);
    h += `<tr class="rf"><td class="dim">🚜 ${finca}</td>`;
    fTot.forEach(v => h += `<td>${v>0?(key==='kl'?N(v,0):U(v,0)):'—'}</td>`);
    h += `</tr>`;

    Object.keys(tree[finca]).sort().forEach(cat => {
      const cTot = ciclos.map(c => { let v=0; Object.values(tree[finca][cat]).forEach(cy=>{v+=cy[c]?.[key]||0;}); return v; });
      h += `<tr class="rc"><td class="dim">${cat}</td>`;
      cTot.forEach(v => h += `<td>${v>0?(key==='kl'?N(v,0):U(v,0)):'—'}</td>`);
      h += `</tr>`;

      Object.keys(tree[finca][cat]).sort().forEach(cuenta => {
        const rowVals = ciclos.map(c => tree[finca][cat][cuenta][c]?.[key] || null);
        const validVals = rowVals.filter(v=>v!=null && v>0);
        const min = validVals.length>1 ? Math.min(...validVals) : null;
        const max = validVals.length>1 ? Math.max(...validVals) : null;
        h += `<tr class="ra"><td class="dim">${cuenta}</td>`;
        ciclos.forEach((c,i) => {
          const cell = tree[finca][cat][cuenta][c];
          const v = cell?.[key] || 0;
          if (v>0) {
            const dkey = `${finca}|${cat}|${cuenta}|${c}`;
            _detailStore[dkey] = cell;
            const cls = min!=null ? (v===min?'cell-ok':v===max?'cell-bad':'') : '';
            h += `<td class="${cls}" onclick="openDetail('${dkey.replace(/'/g,"\\'")}')">${key==='kl'?N(v,0):U(v,0)}</td>`;
          } else h += `<td>—</td>`;
        });
        h += `</tr>`;
      });
    });
  });

  h += `<tr class="rt"><td class="dim">Total general</td>`;
  grandTot.forEach(v => h += `<td><strong>${key==='kl'?N(v,0):U(v,0)}</strong></td>`);
  h += `</tr></tbody>`;
  document.getElementById('t-kl').innerHTML = h;
}

function openCicloDetail(ciclo) {
  if (!CTX) return;
  const rows = CTX.rows.filter(r=>r.Ciclo===ciclo);
  const semilla = { kl:0, usd:0 };
  const insumos = {};
  rows.forEach(r => {
    const kl = (parseFloat(r.Cantidad_Consumo)||0)*KL_FACTOR(r.um);
    const usd = parseFloat(r.Monto_Consumo)||0;
    if (r.Clasificacion === 'Semilla') { semilla.kl += kl; semilla.usd += usd; }
    else {
      const cuenta = r.CuentaContableDescripcion || r.CUENTA_CONTABLE || 'Sin cuenta';
      if (!insumos[cuenta]) insumos[cuenta] = {kl:0,usd:0};
      insumos[cuenta].kl += kl; insumos[cuenta].usd += usd;
    }
  });
  let items = [{label:'Semilla', kl:semilla.kl, usd:semilla.usd}];
  Object.keys(insumos).forEach(c => items.push({label:c, kl:insumos[c].kl, usd:insumos[c].usd}));
  items = items.filter(i=>i.kl>0||i.usd>0).sort((a,b)=> (currentMetric==='kl'?b.kl-a.kl:b.usd-a.usd));

  const mzn = CTX.mznByCiclo[ciclo]||0;
  const t = CTX.totCiclo[ciclo];

  document.getElementById('modal-title').textContent = ciclo;
  document.getElementById('modal-sub').textContent = `${N(mzn,1)} Mzn sembrada`;

  let b = `<div class="modal-sum">
    <div class="it"><b>${N(t.klMzn,1)}</b><span>KL / Mzn</span></div>
    <div class="it"><b>${U(t.usdMzn,2)}</b><span>U$ / Mzn</span></div>
    <div class="it"><b>${N(t.kl,0)}</b><span>KL total</span></div>
    <div class="it"><b>${U(t.usd,0)}</b><span>U$ total</span></div>
  </div>`;
  b += `<table><thead><tr><th class="left">Categoría / Cuenta</th><th>KL</th><th>U$</th></tr></thead><tbody>`;
  items.forEach(i => {
    b += `<tr><td class="left">${i.label}</td><td>${N(i.kl,0)}</td><td>${U(i.usd,0)}</td></tr>`;
  });
  b += `</tbody></table>`;
  document.getElementById('modal-body').innerHTML = b;
  document.getElementById('modal-bg').classList.add('show');
}

function openMesDetail(ciclo, mes) {
  if (!CTX || !CTX.monthly[ciclo]) return;
  const m = CTX.monthly[ciclo][mes] || {kl:0,usd:0};
  const mzn = CTX.mznByCiclo[ciclo]||0;
  const klMzn = mzn>0 ? m.kl/mzn : 0;
  const usdMzn = mzn>0 ? m.usd/mzn : 0;

  document.getElementById('modal-title').textContent = `${MESES_LBL[mes-1]} · ${ciclo}`;
  document.getElementById('modal-sub').textContent = 'Valores del mes (no acumulados)';
  document.getElementById('modal-body').innerHTML = `<div class="modal-sum">
    <div class="it"><b>${N(m.kl,0)}</b><span>KL del mes</span></div>
    <div class="it"><b>${U(m.usd,0)}</b><span>U$ del mes</span></div>
    <div class="it"><b>${N(klMzn,2)}</b><span>KL / Mzn</span></div>
    <div class="it"><b>${U(usdMzn,3)}</b><span>U$ / Mzn</span></div>
  </div>`;
  document.getElementById('modal-bg').classList.add('show');
}

function openDetail(key) {
  const cell = _detailStore[key]; if (!cell) return;
  const [finca,cat,cuenta,ciclo] = key.split('|');
  document.getElementById('modal-title').textContent = cuenta;
  document.getElementById('modal-sub').textContent = `${finca} · ${cat} · Ciclo ${ciclo}`;
  let b = `<table><thead><tr><th class="left">UM</th><th>Cantidad</th><th>KL</th><th>U$</th></tr></thead><tbody>`;
  cell.rows.forEach(r => {
    const kl = (parseFloat(r.Cantidad_Consumo)||0)*KL_FACTOR(r.um);
    b += `<tr><td class="left">${r.um||'—'}</td><td>${N(parseFloat(r.Cantidad_Consumo)||0,1)}</td><td>${N(kl,1)}</td><td>${U(parseFloat(r.Monto_Consumo)||0,0)}</td></tr>`;
  });
  b += `<tr><td class="left"><strong>Total</strong></td><td></td><td><strong>${N(cell.kl,1)}</strong></td><td><strong>${U(cell.usd,0)}</strong></td></tr></tbody></table>`;
  document.getElementById('modal-body').innerHTML = b;
  document.getElementById('modal-bg').classList.add('show');
}
function closeModal(){ document.getElementById('modal-bg').classList.remove('show'); }

function ld(v){document.getElementById('lbar').classList.toggle('show',v);}
function sc(ok,msg){
  document.getElementById('dot').className='dot'+(ok===true?' ok':ok===false?' err':'');
  document.getElementById('ctxt').textContent=msg;
}

init();
</script>
