<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>COMASA DA · Eficiencia Semilla &amp; Insumos</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');
:root{
  --ink:#1e293b; --ink2:#475569; --ink3:#94a3b8;
  --bg:#eef4f0;
  --primary:#1b4332; --primary2:#2d6a4f; --secondary:#40916c; --secondary2:#52b788;
  --accent:#e76f51;
  --glass-shadow:6px 6px 16px rgba(45,106,79,.14),-4px -4px 12px rgba(255,255,255,.9);
  --glass-shadow-sm:4px 4px 10px rgba(45,106,79,.12),-3px -3px 8px rgba(255,255,255,.9);
  --content-w:1700px;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;min-width:0}
html,body{overflow-x:hidden}
body{font-family:'Inter',system-ui,sans-serif;background:var(--bg);color:var(--ink);font-size:13px}
header{background:linear-gradient(135deg,#1b4332 0%,#2d6a4f 55%,#40916c 100%);color:#fff;min-height:56px;padding:.6rem 1.5rem;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:300;box-shadow:0 6px 20px rgba(27,67,50,.3);flex-wrap:wrap;gap:8px}
.brand{display:flex;align-items:center;gap:10px}
.brand-ico{width:30px;height:30px;background:var(--accent);border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:15px;flex-shrink:0}
.brand-name{font-size:15px;font-weight:700}.brand-sub{font-size:11px;opacity:.75}
.conn{display:flex;align-items:center;gap:6px;font-size:11px;background:rgba(255,255,255,.15);padding:4px 12px;border-radius:20px;flex-shrink:0}
.dot{width:8px;height:8px;border-radius:50%;background:#f4a261;flex-shrink:0}.dot.ok{background:#52b788}.dot.err{background:#e76f51}
.lbar{height:3px;background:linear-gradient(90deg,var(--secondary2),var(--primary2),var(--accent));position:fixed;top:0;left:0;right:0;z-index:400;animation:ld 1.2s ease-in-out infinite;display:none}
.lbar.show{display:block}
@keyframes ld{0%{transform:translateX(-100%)}100%{transform:translateX(100%)}}

.sel-panel{background:linear-gradient(135deg,#f2f7f4,#e8f1ec);padding:.9rem 1.5rem;position:sticky;top:0;z-index:200;box-shadow:0 4px 16px rgba(45,106,79,.12)}
.sel-inner{max-width:var(--content-w);margin:0 auto}
.sel-grid{display:grid;grid-template-columns:minmax(0,1.8fr) minmax(0,1.8fr) minmax(0,1.3fr) minmax(0,1fr) auto;gap:12px;align-items:end}
@media(max-width:900px){.sel-grid{grid-template-columns:1fr}}
.sel-g{display:flex;flex-direction:column;gap:5px;min-width:0}
.sel-lbl{font-size:10px;font-weight:700;color:var(--primary2);text-transform:uppercase;letter-spacing:.5px}
.combo-wrapper{position:relative;min-width:0}
.combo-trigger{min-height:36px;padding:6px 26px 6px 12px;border-radius:14px;font-size:12px;cursor:pointer;display:flex;align-items:center;flex-wrap:wrap;gap:3px;position:relative;background:linear-gradient(135deg,#fbfdfc,#eef5f1);box-shadow:var(--glass-shadow-sm),inset 1px 1px 2px rgba(255,255,255,.7);border:none;color:var(--ink)}
.combo-trigger::after{content:'▾';position:absolute;right:10px;top:50%;transform:translateY(-50%);font-size:11px;color:var(--primary2)}
.combo-placeholder{color:#94a3b8;font-size:12px}
.combo-dropdown{display:none;position:absolute;top:calc(100% + 6px);left:0;right:0;background:linear-gradient(135deg,#fbfdfc,#eef5f1);border-radius:14px;box-shadow:var(--glass-shadow);max-height:260px;overflow-y:auto;z-index:500;padding:6px 4px}
.combo-wrapper.open .combo-dropdown{display:block}
.combo-item{display:flex;align-items:center;gap:8px;padding:7px 10px;font-size:12px;cursor:pointer;border-radius:8px}
.combo-item:hover{background:rgba(64,145,108,.1)}
.combo-item input{width:14px;height:14px;accent-color:var(--secondary);cursor:pointer}
.combo-item label{cursor:pointer;flex:1}
.combo-all{font-weight:700;color:var(--primary2);border-bottom:1px solid rgba(45,106,79,.15);margin-bottom:4px;padding-bottom:8px}
.tag-mini{background:linear-gradient(135deg,#dff3e7,#c8ead9);color:var(--primary);border-radius:8px;padding:2px 8px;font-size:11px;font-weight:700}
.sel-g select{height:36px;padding:0 10px;border-radius:14px;font-size:12px;cursor:pointer;background:linear-gradient(135deg,#fbfdfc,#eef5f1);border:none;color:var(--ink);box-shadow:var(--glass-shadow-sm);appearance:none;width:100%}

main{padding:1.4rem 1.5rem;max-width:var(--content-w);margin:0 auto}
.empty{border-radius:20px;padding:3rem;text-align:center;color:var(--ink3);background:linear-gradient(135deg,#fbfdfc,#eef5f1);box-shadow:var(--glass-shadow)}
.empty .ico{font-size:48px;margin-bottom:1rem}
.empty h3{font-size:16px;font-weight:700;color:var(--primary2);margin-bottom:6px}

.toggle-wrap{display:flex;justify-content:center;margin-bottom:4px}
.toggle{background:#fff;border-radius:20px;padding:4px;display:inline-flex;gap:2px;box-shadow:var(--glass-shadow-sm)}
.toggle button{border:none;background:transparent;font-size:11px;font-weight:700;padding:7px 20px;border-radius:16px;cursor:pointer;color:var(--ink3);font-family:inherit;white-space:nowrap}
.toggle button.active{background:var(--primary2);color:#fff}
.toggle.mini button{padding:5px 12px;font-size:10px}
.toggle-hint{text-align:center;font-size:10px;color:var(--ink3);margin-bottom:1.3rem}

.grid-2{display:grid;grid-template-columns:minmax(0,1.3fr) minmax(0,1fr);gap:1.4rem;margin-bottom:1.4rem;align-items:start}
@media(max-width:1000px){.grid-2{grid-template-columns:1fr}}

.cc{border-radius:20px;padding:1.1rem;background:linear-gradient(135deg,#ffffff,#f5faf7);box-shadow:var(--glass-shadow);margin-bottom:1.4rem;min-width:0}
.cc h3{font-size:11px;font-weight:800;color:var(--primary2);margin-bottom:2px;text-transform:uppercase;letter-spacing:.3px}
.cc p.hint{font-size:10px;color:var(--ink3);margin-bottom:10px}
.grid-2 .cc{margin-bottom:0}
.cc-hdr{display:flex;justify-content:space-between;align-items:flex-start;gap:10px;flex-wrap:wrap;margin-bottom:6px}
.cc-hdr .titles{min-width:0}
.cc-controls{display:flex;align-items:center;gap:8px;flex-wrap:wrap}
.cc-controls select{height:28px;padding:0 8px;border-radius:10px;font-size:10px;border:none;background:#eef5f1;box-shadow:var(--glass-shadow-sm);color:var(--ink)}
.cc-controls .lbl{font-size:9px;color:var(--ink3);text-transform:uppercase;font-weight:700}

.heat-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(230px,1fr));gap:14px}
.heat-card{min-width:0}
.heat-title{font-size:10px;font-weight:800;color:var(--primary);margin-bottom:6px}
.heat-table{border-collapse:collapse;font-size:9px;width:100%}
.heat-table th{font-weight:700;color:var(--ink3);font-size:8px;padding:2px 3px;text-align:center}
.heat-table td{text-align:center;padding:4px 3px;cursor:pointer;color:var(--ink);border-radius:4px;font-size:8px}
.heat-table td.heat-finca{text-align:left;cursor:default;color:var(--ink2);font-weight:700;padding-right:6px;white-space:nowrap}
.heat-table td.heat-empty{color:var(--ink3);cursor:default}
.heat-legend{display:flex;align-items:center;gap:6px;margin-top:10px;font-size:9px;color:var(--ink2)}
.heat-legend .bar{width:70px;height:8px;border-radius:4px;background:linear-gradient(90deg,rgba(82,183,136,.6),rgba(231,111,81,.6))}

details.detail-block{border-radius:20px;background:linear-gradient(135deg,#ffffff,#f5faf7);box-shadow:var(--glass-shadow);overflow:hidden}
details.detail-block summary{cursor:pointer;list-style:none;padding:.9rem 1.2rem;font-size:12px;font-weight:800;color:var(--primary);display:flex;justify-content:space-between;align-items:center}
details.detail-block summary::-webkit-details-marker{display:none}
details.detail-block summary::after{content:'▾ Ver detalle';font-size:10px;font-weight:600;color:var(--secondary)}
details.detail-block[open] summary::after{content:'▴ Ocultar'}
.matrix-scroll{overflow-x:auto;max-height:480px;overflow-y:auto;padding:0 .3rem .8rem}
.mt{border-collapse:collapse;font-size:11px;white-space:nowrap;min-width:100%}
.mt th{padding:5px 10px;font-weight:700;font-size:10px;color:var(--ink2);border-bottom:1px solid rgba(45,106,79,.18);text-align:right;background:rgba(240,248,243,.95);position:sticky;top:0}
.mt th.left{text-align:left;min-width:190px}
.mt th.ciclo{background:rgba(64,145,108,.16);color:var(--primary);font-size:11px;font-weight:800;min-width:75px}
.mt td{padding:5px 10px;border-bottom:1px solid rgba(45,106,79,.08);text-align:right;cursor:pointer}
.mt td.dim{text-align:left;cursor:default}
.mt tr.rf td{font-weight:800;background:rgba(64,145,108,.09);color:var(--primary)}
.mt tr.rc td{background:rgba(240,248,243,.6);color:var(--primary2);font-weight:700}
.mt tr.rc td.dim{padding-left:18px}
.mt tr.ra td.dim{padding-left:34px;color:var(--ink2)}
.mt tr.rt td{font-weight:800;background:linear-gradient(135deg,rgba(82,183,136,.18),rgba(82,183,136,.08));color:var(--primary);border-top:2px solid rgba(82,183,136,.4)}
.mt tbody tr:hover td:not(.dim){outline:1px solid rgba(64,145,108,.35);outline-offset:-1px}
.cell-ok{background:rgba(82,183,136,.18)!important;color:#065f46;font-weight:700}
.cell-bad{background:rgba(231,111,81,.16)!important;color:#a2440f;font-weight:700}

.modal-bg{display:none;position:fixed;inset:0;background:rgba(20,40,30,.5);z-index:900;align-items:center;justify-content:center;backdrop-filter:blur(3px)}
.modal-bg.show{display:flex}
.modal{width:min(560px,92vw);max-height:80vh;overflow-y:auto;background:linear-gradient(135deg,#ffffff,#f2f8f4);border-radius:20px;box-shadow:0 20px 50px rgba(20,40,30,.3);padding:1.4rem}
.modal-hdr{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:1rem}
.modal-hdr h3{font-size:14px;font-weight:800;color:var(--primary)}
.modal-hdr span{font-size:10px;color:var(--ink3)}
.modal-x{background:none;border:none;font-size:18px;cursor:pointer;color:var(--ink3);line-height:1}
.modal table{width:100%;border-collapse:collapse;font-size:11px}
.modal th{text-align:right;padding:5px 8px;color:var(--ink3);font-size:10px;border-bottom:1px solid rgba(45,106,79,.18)}
.modal th.left{text-align:left}
.modal td{padding:5px 8px;text-align:right;border-bottom:1px solid rgba(45,106,79,.08)}
.modal td.left{text-align:left;color:var(--primary2);font-weight:700}
.modal-sum{display:flex;gap:16px;margin-bottom:.8rem;flex-wrap:wrap}
.modal-sum .it{background:rgba(64,145,108,.08);border-radius:10px;padding:6px 12px}
.modal-sum .it b{display:block;font-size:13px;color:var(--primary)}
.modal-sum .it span{font-size:9px;color:var(--ink3);text-transform:uppercase}

footer{text-align:center;padding:1.2rem 0 .8rem;font-size:10px;color:var(--ink3);font-weight:600}
</style>
</head>
<body>
<div class="lbar" id="lbar"></div>

<header>
  <div class="brand">
    <div class="brand-ico">🌾</div>
    <div>
      <div class="brand-name">COMASA · DA</div>
      <div class="brand-sub">Eficiencia de Consumo · Semilla &amp; Insumos Agrícolas</div>
    </div>
  </div>
  <div class="conn"><span class="dot" id="dot"></span><span id="ctxt">Iniciando...</span></div>
</header>

<div class="sel-panel">
  <div class="sel-inner">
    <div class="sel-grid">
      <div class="sel-g">
        <span class="sel-lbl">Ciclos</span>
        <div class="combo-wrapper" id="wr-ciclo">
          <div class="combo-trigger" onclick="tog('wr-ciclo')">
            <span class="combo-placeholder" id="ph-ciclo">Cargando...</span>
          </div>
          <div class="combo-dropdown" id="dd-ciclo"></div>
        </div>
      </div>
      <div class="sel-g">
        <span class="sel-lbl">Finca / Centro</span>
        <div class="combo-wrapper" id="wr-centro">
          <div class="combo-trigger" onclick="tog('wr-centro')">
            <span class="combo-placeholder" id="ph-centro">Cargando...</span>
          </div>
          <div class="combo-dropdown" id="dd-centro"></div>
        </div>
      </div>
      <div class="sel-g">
        <span class="sel-lbl">Sector</span>
        <div class="combo-wrapper" id="wr-sector">
          <div class="combo-trigger" onclick="tog('wr-sector')">
            <span class="combo-placeholder" id="ph-sector">Cargando...</span>
          </div>
          <div class="combo-dropdown" id="dd-sector"></div>
        </div>
      </div>
      <div class="sel-g">
        <span class="sel-lbl">Cierre</span>
        <select id="f-cierre" onchange="recomputeAll()">
          <option value="N" selected>Abierto (N)</option>
          <option value="S">Cerrado (S)</option>
          <option value="">Todos</option>
        </select>
      </div>
      <div class="sel-g">
        <span class="sel-lbl">Métrica</span>
        <div class="toggle">
          <button id="btn-kl" onclick="setMetric('kl')">KL</button>
          <button id="btn-usd" class="active" onclick="setMetric('usd')">U$</button>
        </div>
      </div>
    </div>
  </div>
</div>

<main>
  <div class="empty" id="empty">
    <div class="ico">🌱</div>
    <h3>Cargando datos de Semilla &amp; Insumos Agrícolas...</h3>
    <p>Todos los ciclos y fincas se muestran automáticamente.</p>
  </div>

  <div id="dash" style="display:none">

    <div class="grid-2">
      <div class="cc">
        <h3 id="h-ciclo">MANZANAS SEMBRADAS VS EFICIENCIA (—/MZN) POR CICLO</h3>
        <p class="hint">Barras = manzanas sembradas · Línea = indicador de eficiencia · Clic en una barra para ver el detalle del ciclo</p>
        <div style="position:relative;height:280px"><canvas id="ch-ciclo"></canvas></div>
      </div>
      <div class="cc">
        <h3 id="h-comp">PESO POR CATEGORÍA / CUENTA</h3>
        <p class="hint">Participación de Semilla y cada cuenta de Insumos Agrícolas sobre el total</p>
        <div style="position:relative;height:280px"><canvas id="ch-comp"></canvas></div>
      </div>
    </div>

    <div class="grid-2">
      <div class="cc">
        <h3 id="h-grupo">RESUMEN POR GRUPO / FAMILIA — (—) ABSOLUTO</h3>
        <p class="hint">Clic en un valor para ver el desglose por finca (KL, U$ y sus indicadores /Mzn)</p>
        <div class="matrix-scroll"><table class="mt" id="t-grupo"></table></div>
      </div>
      <div class="cc">
        <h3 id="h-grupo-mzn">RESUMEN POR GRUPO / FAMILIA — (—) / MZN</h3>
        <p class="hint">Mismo desglose, dividido entre manzanas sembradas de cada ciclo</p>
        <div class="matrix-scroll"><table class="mt" id="t-grupo-mzn"></table></div>
      </div>
    </div>

    <div class="cc">
      <h3 id="h-heat">EFICIENCIA POR FINCA Y CICLO — POR CATEGORÍA (—/MZN)</h3>
      <p class="hint">Verde = eficiente · Rojo = alto consumo (escala relativa dentro de cada categoría) · Clic en una celda para ver el detalle</p>
      <div id="heat-container" class="heat-grid"></div>
    </div>

    <div class="cc">
      <div class="cc-hdr">
        <div class="titles">
          <h3 id="h-mensual">—/MZN ACUMULADO · COMPARADO MES A MES ENTRE CICLOS</h3>
          <p class="hint">Clic en un punto para ver el detalle del mes en ese ciclo</p>
        </div>
        <div class="cc-controls">
          <span class="lbl">Desde</span>
          <select id="mes-desde" onchange="onMonthRangeChange()"></select>
          <span class="lbl">Hasta</span>
          <select id="mes-hasta" onchange="onMonthRangeChange()"></select>
          <div class="toggle mini">
            <button id="btn-acum" class="active" onclick="setViewMode('acum')">Acumulado</button>
            <button id="btn-mensual" onclick="setViewMode('mensual')">Mensual</button>
          </div>
        </div>
      </div>
      <div style="position:relative;height:280px"><canvas id="ch-mensual"></canvas></div>
    </div>

    <div class="cc">
      <h3 id="h-finca">— / MZN POR FINCA — TODOS LOS CICLOS</h3>
      <p class="hint">Comparación entre ciclos por finca — identifica dónde se concentra la ineficiencia</p>
      <div style="position:relative;height:300px"><canvas id="ch-finca"></canvas></div>
    </div>

    <div class="cc">
      <h3 id="h-sector">— / MZN POR SECTOR — TODOS LOS CICLOS</h3>
      <p class="hint">Comparación entre ciclos agrupada por sector</p>
      <div style="position:relative;height:280px"><canvas id="ch-sector"></canvas></div>
    </div>

    <details class="detail-block" style="margin-bottom:1.4rem">
      <summary id="det-summary">Detalle · Finca → Categoría → Cuenta</summary>
      <div class="matrix-scroll"><table class="mt" id="t-kl"></table></div>
    </details>

  </div>
</main>

<footer>COMASA DA · Sistema de Información · Semilla &amp; Insumos Agrícolas</footer>

<div class="modal-bg" id="modal-bg" onclick="if(event.target===this)closeModal()">
  <div class="modal">
    <div class="modal-hdr">
      <div><h3 id="modal-title">Detalle</h3><span id="modal-sub"></span></div>
      <button class="modal-x" onclick="closeModal()">✕</button>
    </div>
    <div id="modal-body"></div>
  </div>
</div>

<script>
Chart.register(ChartDataLabels);
Chart.defaults.set('plugins.datalabels', { display:false });

const esIntranet = window.location.hostname === '192.168.5.58' ||
                   window.location.hostname === 'localhost' ||
                   window.location.hostname.startsWith('192.168.');
const API = esIntranet ? 'http://192.168.5.58:5000' : 'https://sia.comasa.com.ni/dab';
const CLASIF_FOCO = ['Semilla','Insumos Agricolas'];
const CYCLE_COLORS = ['#2d6a4f','#2E6FBA','#e76f51','#8e44ad','#c0392b','#52b788','#0f6e56'];
const COMP_COLORS = ['#2d6a4f','#2E6FBA','#8e44ad','#e76f51','#52b788','#0f6e56','#c0392b','#94a3b8'];
const BAR_SOFT = 'rgba(64,145,108,.35)';
const LINE_STRONG = '#1b4332';
const MESES_LBL = ['Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'];
const GRUPO_ORDEN = ['Semilla','Fertilizantes','Protectores de Cultivo'];

const SECTOR_MAP_RAW = {
  1: ['La Laguna','La Pistola','Llano Verde','Montana','Palmira','Palo de Pan','Quinta Maria','Rancho Pando','Roma','San Martin','Santa Isabel','Santa Rosa'],
  2: ['Las Americas','La Concha','Miramar','San Luis'],
  4: ['San Blas']
};
function norm(s) {
  return (s||'').toString().toLowerCase()
    .normalize('NFD').replace(/[\u0300-\u036f]/g,'')
    .replace(/\bfinca\b/g,'').replace(/\s+/g,' ').trim();
}
const SECTOR_LOOKUP = {};
Object.keys(SECTOR_MAP_RAW).forEach(sec => {
  SECTOR_MAP_RAW[sec].forEach(f => { SECTOR_LOOKUP[norm(f)] = sec; });
});
function sectorOf(finca) {
  const s = SECTOR_LOOKUP[norm(finca)];
  return s ? `Sector ${s}` : 'Sin sector asignado';
}

function classifyGrupo(clasificacion, cuenta) {
  if (clasificacion === 'Semilla') return { grupo:'Semilla', familia:'Semilla' };
  const c = (cuenta||'').toLowerCase();
  if (c.includes('fertilizante')) return { grupo:'Fertilizantes', familia:cuenta||'Fertilizantes' };
  if (c.includes('fungu')||c.includes('fungi')||c.includes('insecti')||c.includes('herbi')||c.includes('adherente'))
    return { grupo:'Protectores de Cultivo', familia:cuenta||'Otros' };
  return { grupo: cuenta||'Otros', familia: cuenta||'Otros' };
}

let relaciones = [], areaSiembra = [], factRows = [];
let allCiclos = [], allFincas = [], allSectores = [];
let selCiclos = new Set(), selFincas = new Set(), selSectores = new Set();
let charts = {};
let _detailStore = {};
let currentMetric = 'usd';
let viewMode = 'acum';
let mesDesde = 1, mesHasta = 12;

const N = (n,d=0) => n==null||isNaN(n)?'—':parseFloat(n).toLocaleString('en-US',{minimumFractionDigits:d,maximumFractionDigits:d});
const U = (n,d=0) => n==null||isNaN(n)||n===0?'—':'$'+N(n,d);
const KL_FACTOR = um => {
  if (!um) return 1;
  switch(um.trim().toUpperCase()) {
    case 'GLN': return 3.78;
    case 'QQ': case 'QUINTAL': return 45.454;
    case 'GR': case 'GRA': return 0.001;
    case 'LIB': case 'LBR': return 0.45454;
    default: return 1;
  }
};
const colorOf = ciclo => CYCLE_COLORS[allCiclos.indexOf(ciclo)%CYCLE_COLORS.length] || '#52b788';
const unitLbl  = () => currentMetric==='kl' ? 'KL' : 'U$';
const mznKeyOf = () => currentMetric==='kl' ? 'klMzn' : 'usdMzn';
const fmtLineLbl = v => currentMetric==='kl' ? N(v,1) : U(v,2);

function tog(id) {
  const el = document.getElementById(id);
  const op = el.classList.contains('open');
  document.querySelectorAll('.combo-wrapper').forEach(w=>w.classList.remove('open'));
