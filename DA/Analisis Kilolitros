          const pct = total>0 ? (ctx.parsed/total*100) : 0;
          return `${ctx.label}: ${currentMetric==='kl'?N(ctx.parsed,0)+' KL':U(ctx.parsed,0)} (${N(pct,1)}%)`;
        }}}
      }
    }
  });
}

