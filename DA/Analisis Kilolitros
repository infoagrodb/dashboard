let CTX = null;

function recomputeAll() {
  const cierre = document.getElementById('f-cierre').value;
  const ciclos = allCiclos.filter(c=>selCiclos.has(c));
  const fincas = allFincas.filter(f=>selFincas.has(f.finca) && selSectores.has(sectorOf(f.finca))).map(f=>f.finca);
  const fincasSet = new Set(fincas);

  const rows = factRows.filter(r =>
    selCiclos.has(r.Ciclo) && fincasSet.has(r.Finca) && (cierre===''||r.Cierre===cierre)
  );

  const mznByCiclo = {};
  ciclos.forEach(c => {
    mznByCiclo[c] = fincas.reduce((s,f)=> s + areaSiembra.filter(a=>a.Ciclo===c&&a.Finca===f).reduce((s2,a)=>s2+(parseFloat(a.AvanceMzn)||0),0), 0);
  });
  const mznByCicloFinca = {};
  ciclos.forEach(c=> fincas.forEach(f=>{
    mznByCicloFinca[`${c}|${f}`] = areaSiembra.filter(a=>a.Ciclo===c&&a.Finca===f).reduce((s,a)=>s+(parseFloat(a.AvanceMzn)||0),0);
  }));

  CTX = { ciclos, fincas, rows, mznByCiclo, mznByCicloFinca };

  if (!ciclos.length || !fincas.length || !rows.length) {
    Object.keys(charts).forEach(id=>{ if(charts[id]){charts[id].destroy();charts[id]=null;} });
    document.getElementById('t-kl').innerHTML='';
    return;
  }

  const totCiclo = {};
  ciclos.forEach(c => { totCiclo[c] = {kl:0, usd:0}; });
  rows.forEach(r => {
    const t = totCiclo[r.Ciclo]; if(!t) return;
    t.kl  += (parseFloat(r.Cantidad_Consumo)||0)*KL_FACTOR(r.um);
    t.usd += parseFloat(r.Monto_Consumo)||0;
  });
  ciclos.forEach(c => {
    const mzn = mznByCiclo[c]||0;
    totCiclo[c].klMzn  = mzn>0 ? totCiclo[c].kl/mzn : 0;
    totCiclo[c].usdMzn = mzn>0 ? totCiclo[c].usd/mzn : 0;
  });

  const totFC = {};
  rows.forEach(r => {
    const key = `${r.Finca}|${r.Ciclo}`;
    if (!totFC[key]) totFC[key] = {kl:0, usd:0};
    totFC[key].kl  += (parseFloat(r.Cantidad_Consumo)||0)*KL_FACTOR(r.um);
    totFC[key].usd += parseFloat(r.Monto_Consumo)||0;
  });

  const tree = {};
  rows.forEach(r => {
    const finca = r.Finca; if (!fincas.includes(finca)) return;
    const cat = r.Clasificacion || 'Sin categoría';
    const cuenta = r.CuentaContableDescripcion || r.CUENTA_CONTABLE || 'Sin cuenta';
    const kl = (parseFloat(r.Cantidad_Consumo)||0)*KL_FACTOR(r.um);
    const usd = parseFloat(r.Monto_Consumo)||0;
    tree[finca] = tree[finca]||{};
    tree[finca][cat] = tree[finca][cat]||{};
    tree[finca][cat][cuenta] = tree[finca][cat][cuenta]||{};
    tree[finca][cat][cuenta][r.Ciclo] = tree[finca][cat][cuenta][r.Ciclo] || {kl:0,usd:0,rows:[]};
    tree[finca][cat][cuenta][r.Ciclo].kl += kl;
    tree[finca][cat][cuenta][r.Ciclo].usd += usd;
    tree[finca][cat][cuenta][r.Ciclo].rows.push(r);
  });

  // Mensual por ciclo (usando campo Fecha)
  const monthly = {};
  ciclos.forEach(c => { monthly[c] = Array.from({length:13},()=>({kl:0,usd:0})); });
  rows.forEach(r => {
    if (!r.FECHA) return;
    const d = new Date(r.FECHA);
    if (isNaN(d)) return;
    const m = d.getMonth()+1;
    if (!monthly[r.Ciclo]) return;
    monthly[r.Ciclo][m].kl  += (parseFloat(r.Cantidad_Consumo)||0)*KL_FACTOR(r.um);
    monthly[r.Ciclo][m].usd += parseFloat(r.Monto_Consumo)||0;
  });

  // Árbol Grupo->Familia->Ciclo (agregado, todas las fincas seleccionadas)
  const treeGF = {};
  rows.forEach(r => {
    const { grupo, familia } = classifyGrupo(r.Clasificacion, r.CuentaContableDescripcion || r.CUENTA_CONTABLE);
    const kl = (parseFloat(r.Cantidad_Consumo)||0)*KL_FACTOR(r.um);
    const usd = parseFloat(r.Monto_Consumo)||0;
    treeGF[grupo] = treeGF[grupo]||{};
    treeGF[grupo][familia] = treeGF[grupo][familia]||{};
    treeGF[grupo][familia][r.Ciclo] = treeGF[grupo][familia][r.Ciclo] || {kl:0,usd:0};
    treeGF[grupo][familia][r.Ciclo].kl += kl;
    treeGF[grupo][familia][r.Ciclo].usd += usd;
  });

  // Árbol Finca->Grupo->Ciclo (para mapa de calor)
  const treeFGC = {};
  rows.forEach(r => {
    const { grupo } = classifyGrupo(r.Clasificacion, r.CuentaContableDescripcion || r.CUENTA_CONTABLE);
    const finca = r.Finca;
    const kl = (parseFloat(r.Cantidad_Consumo)||0)*KL_FACTOR(r.um);
    const usd = parseFloat(r.Monto_Consumo)||0;
    treeFGC[grupo] = treeFGC[grupo]||{};
    treeFGC[grupo][finca] = treeFGC[grupo][finca]||{};
    treeFGC[grupo][finca][r.Ciclo] = treeFGC[grupo][finca][r.Ciclo] || {kl:0,usd:0};
    treeFGC[grupo][finca][r.Ciclo].kl += kl;
    treeFGC[grupo][finca][r.Ciclo].usd += usd;
  });

  CTX.totCiclo = totCiclo;
  CTX.totFC = totFC;
  CTX.tree = tree;
  CTX.treeGF = treeGF;
  CTX.treeFGC = treeFGC;
  CTX.monthly = monthly;

  renderAll();
}

