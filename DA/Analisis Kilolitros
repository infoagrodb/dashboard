async function fetchAllPages(url) {
  let out = [], next = url, guard = 0;
  while (next && guard < 100) {
    const res = await fetch(next).then(r=>r.json());
    out = out.concat(res.value || []);
    next = res.nextLink || null;
    guard++;
  }
  return out;
}

async function init() {
  ld(true); sc(null,'Cargando catálogos...');
  buildMonthSelects();
  try {
    const fClasif = '('+CLASIF_FOCO.map(c=>`Clasificacion eq '${c}'`).join(' or ')+')';
    const [v1, v2, v3] = await Promise.all([
      fetchAllPages(`${API}/api/DW_InfoAgro_RelacionCicloFinca?$orderby=Ciclo,Finca&$first=200`),
      fetchAllPages(`${API}/api/DW_InfoAgro_AreaSiembra?$filter=CategoriaActividad eq 'Siembra'&$first=500`),
      fetchAllPages(`${API}/api/IS_DW_ActivoBiologicoDA?$filter=${encodeURIComponent(fClasif)}&$first=5000`)
    ]);
    relaciones = v1; areaSiembra = v2; factRows = v3;

    allCiclos = [...new Set(relaciones.map(r=>r.Ciclo).filter(Boolean))].filter(c=>/^mani/i.test(c)).sort();
    const vistos = new Set();
    allFincas = [];
    relaciones.forEach(r=>{ if(!vistos.has(r.CentroCC)){vistos.add(r.CentroCC); allFincas.push({centro:r.CentroCC, finca:r.Finca});} });

    selCiclos = new Set(allCiclos);
    selFincas = new Set(allFincas.map(f=>f.finca));
    allSectores = [...new Set(allFincas.map(f=>sectorOf(f.finca)))].sort();
    selSectores = new Set(allSectores);

    buildCicloCombo();
    buildCentroCombo();
    buildSectorCombo();

    document.getElementById('empty').style.display='none';
    document.getElementById('dash').style.display='block';
    sc(true,`${factRows.length} registros · ${allCiclos.length} ciclos · listo`);
    recomputeAll();
  } catch(e) {
    sc(false,'Error: '+e.message);
  }
  ld(false);
}

