function renderChartComp(rows) {
  if (charts['ch-comp']) charts['ch-comp'].destroy();
  const key = currentMetric==='kl' ? 'kl' : 'usd';
  const semillaTot = { v:0 };
  const insumoCuentas = {};
  rows.forEach(r => {
    const val = key==='kl' ? (parseFloat(r.Cantidad_Consumo)||0)*KL_FACTOR(r.um) : (parseFloat(r.Monto_Consumo)||0);
    if (r.Clasificacion === 'Semilla') {
      semillaTot.v += val;
    } else {
      const cuenta = r.CuentaContableDescripcion || r.CUENTA_CONTABLE || 'Sin cuenta';
      insumoCuentas[cuenta] = (insumoCuentas[cuenta]||0) + val;
    }
  });
  let slices = [{label:'Semilla', value:semillaTot.v}];
  Object.keys(insumoCuentas).forEach(c => slices.push({label:c, value:insumoCuentas[c]}));
  slices = slices.filter(s=>s.value>0).sort((a,b)=>b.value-a.value);
  if (slices.length > 7) {
    const top = slices.slice(0,6);
    const otros = slices.slice(6).reduce((s,x)=>s+x.value,0);
    slices = [...top, {label:'Otros insumos', value:otros}];
  }
  const total = slices.reduce((s,x)=>s+x.value,0);

  charts['ch-comp'] = new Chart(document.getElementById('ch-comp'), {
    type:'doughnut',
    data:{
      labels: slices.map(s=>s.label),
      datasets:[{ data: slices.map(s=>+s.value.toFixed(1)), backgroundColor: slices.map((_,i)=>COMP_COLORS[i%COMP_COLORS.length]), borderWidth:2, borderColor:'#fff' }]
    },
    options:{
      responsive:true, maintainAspectRatio:false,
      plugins:{
        legend:{position:'bottom', labels:{font:{size:9},boxWidth:9}},
        datalabels:{ display:true, color:'#fff', font:{size:10,weight:'700'}, formatter:(v)=>{ const pct = total>0?(v/total*100):0; return pct>=6 ? N(pct,0)+'%' : ''; } },
