function refreshPh(kind) {
  const ph = document.getElementById('ph-'+kind);
  const sel = kind==='ciclo' ? [...selCiclos] : kind==='sector' ? [...selSectores] : [...selFincas];
  const total = kind==='ciclo' ? allCiclos.length : kind==='sector' ? allSectores.length : allFincas.length;
  const allLbl = kind==='ciclo' ? 'Todos los ciclos' : kind==='sector' ? 'Todos los sectores' : 'Todas las fincas';
  if (sel.length===total) ph.innerHTML = `<span class="tag-mini">${allLbl}</span>`;
  else if (!sel.length) ph.innerHTML = `<span class="combo-placeholder">Ninguno seleccionado</span>`;
  else ph.innerHTML = sel.map(s=>`<span class="tag-mini">${s}</span>`).join(' ');
